# Capka automatic-HTTPS reverse proxy.
# {$DOMAIN} is read from the environment at startup; Caddy provisions and renews
# a Let's Encrypt cert for it automatically (no account email required).
{
	# Optional operator-provided config, generated by scripts/up.sh into
	# ./data/caddy/conf.d (mounted read-only, see docker-compose.tls.yml). Today
	# it carries just an `email` line when ACME_EMAIL is set — which makes Caddy
	# 2.8+ add ZeroSSL as a fallback issuer, so a cert still provisions if
	# sslip.io's shared Let's Encrypt quota is temporarily exhausted. When the
	# directory is empty (the default, no-email happy path) Caddy logs a benign
	# "no files matching" warning and continues with Let's Encrypt only.
	import /etc/caddy/conf.d/*.caddy
}

{$DOMAIN} {
	# Transport hardening. Caddy terminates TLS here, so HSTS belongs at this layer.
	# (CSP is still TODO — it needs a nonce on the inline theme-init script; tracked
	# in next.config.ts.) Header is set on every response, including errors.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
	reverse_proxy platform:3000
	# Allow large uploads (matches the host-nginx client_max_body_size in docs/DEPLOY.md).
	request_body {
		max_size 100MB
	}
	encode zstd gzip
}
