# No .env required! All config is done through the web UI.
# Only set DATABASE_URL if NOT using docker-compose (which auto-configures it).
# DATABASE_URL=postgresql://unClaw:unClaw@localhost:5432/unClaw

# Root of trust for encrypting provider API keys at rest.
# MUST be set in production: it lives OUTSIDE the database, so a DB leak
# alone cannot decrypt stored secrets. Generate one with:
#   openssl rand -hex 32
# If unset, unClaw falls back to a DB-stored key (insecure — dev only).
# UNCLAW_MASTER_KEY=
